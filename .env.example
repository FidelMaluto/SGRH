# GEMINI_API_KEY: Necessário para chamadas à API Gemini AI.
# O AI Studio injeta isto automaticamente em tempo de execução a partir dos segredos do utilizador.
# Os utilizadores configuram isto através do painel de Segredos na UI do AI Studio.
GEMINI_API_KEY="MINHA_CHAVE_API_GEMINI"

# APP_URL: O URL onde este applet está alojado.
# O AI Studio injeta isto automaticamente em tempo de execução com o URL do serviço Cloud Run.
# Usado para links auto-referenciais, callbacks de OAuth e endpoints de API.
APP_URL="MEU_URL_DO_APP"
